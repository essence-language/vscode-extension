{
	"name": "essence",
	"displayName": "Essence",
	"description": "Visual Studio Code Extension for Essence",
	"version": "0.0.1",
	"publisher": "essence-language",
	"repository": {
		"type": "git",
		"url": "https://github.com/essence-language/vscode-extension.git"
	},
	"engines": {
		"vscode": "^1.26.0"
	},
	"categories": [
		"Programming Languages"
	],
	"contributes": {
		"languages": [
			{
				"id": "essence",
				"aliases": [
					"Essence",
					"essence"
				],
				"extensions": [
					".es"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "essence",
				"scopeName": "source.essence",
				"path": "./syntaxes/essence.tmLanguage.json"
			}
		]
	}
}
